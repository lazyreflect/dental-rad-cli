# Project-specific: never commit training data, weights, or PHI
data/                       # DenPAR + Roboflow datasets pulled by download scripts
weights/                    # trained model checkpoints
*.pt
*.pth
*.onnx

# Eval set: only scrubbed copies in examples/eval/ are committed (and only if explicitly added)
examples/eval/originals/    # belt-and-suspenders — originals must NEVER enter the repo
examples/eval/output/       # generated annotation outputs

