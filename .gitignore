# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# uv
.venv/
.uv-cache/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Project-specific: never commit training data, weights, or PHI.
# (Inline `#` comments after the pattern silently break gitignore
# matching in this git version — see commit 18fa849 incident — keep
# comments on their own lines.)
data/
weights/
*.pt
*.pth
*.onnx

# Eval set: scrubbed copies stay LOCAL by default — never enter the public repo.
# Patient-derived images, even scrubbed, are kept off GitHub for v0. A future
# synthetic eval set may be committed under a separate path with its own provenance docs.
examples/eval/*.png
examples/eval/*.jpg
examples/eval/*.jpeg
examples/eval/originals/    # belt-and-suspenders — originals must NEVER enter the repo
examples/eval/output/       # generated annotation outputs

# Test / debug artifacts
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/

# Bulky diagnostic galleries — reproducible via the relevant
# scripts (scripts/dev_contact_sheet.py etc.). Keep the source
# scripts in git; keep the output PNGs out.
output/diagnostics/dev-contact-sheet/
output/diagnostics/severe-sites/*.png

# Notebooks (we don't ship Jupyter — methodology-reference reads them upstream)
*.ipynb
.ipynb_checkpoints/

# Local secrets / env
.env
.env.local
*.secrets
